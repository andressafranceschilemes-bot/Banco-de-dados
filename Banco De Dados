-CONSULTAS

-WHERE + LIKE
SELECT * FROM carros
WHERE modelo LIKE '%o%';


-BETWEEN
SELECT * FROM locacoes
WHERE dias BETWEEN 3 AND 7;


-ORDER BY
SELECT * FROM carros
ORDER BY modelo ASC;


-FUNÇÕES
SELECT
COUNT(*) AS total_locacoes,
AVG(valor_diaria) AS media_diaria
FROM locacoes;



-JOIN
SELECT
clientes.nome,
carros.modelo,
locacoes.dias
FROM locacoes

INNER JOIN clientes
ON locacoes.id_cliente = clientes.id_cliente

INNER JOIN carros
ON locacoes.id_carro = carros.id_carro;



-TRIGGER
-muda o status do carro quando alugado
DELIMITER //

CREATE TRIGGER atualizar_status_carro
AFTER INSERT ON locacoes

FOR EACH ROW
BEGIN

UPDATE carros
SET status='Indisponível'

WHERE id_carro = NEW.id_carro;

END//

DELIMITER ;



-PROCEDURE
DELIMITER //

CREATE PROCEDURE CalcularEntrega(
IN id INT
)

BEGIN

DECLARE total DECIMAL(10,2);
DECLARE multa DECIMAL(10,2);

SELECT dias * valor_diaria
INTO total
FROM locacoes
WHERE id_locacao=id;


IF total > 500 THEN

SET multa = total * 0.10;
SET total = total + multa;

END IF;


SELECT total AS Valor_Final;

END//

DELIMITER ;



